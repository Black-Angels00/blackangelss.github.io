      padding: 30px;
      border: 3px solid #ff3366;
      border-radius: 15px;
      box-shadow: 0 0 40px rgba(255, 51, 102, 0.7);
    }
    h1 { text-shadow: 0 0 25px #ff3366, 0 0 40px #ff0000; font-size: 2.8em; }
